<div id="SearchBox">
    <div class="text-center">
        <h2>Insert Word</h2>
        <p>
            Type or past a word into the box below.
        </p>
    </div>


    <form id="searchForm" method="post" asp-controller="Home" asp-action="SearchWord">
        <div>
            <label for="formGroupExampleInput" class="form-label">Text Box</label>
            <input type="text" class="form-control" id="formGroupExampleInput" placeholder="Text Box" name="searchText">
            <input class="btn btn-primary" type="submit" value="Submit">
        </div>
    </form>
</div>
<hr>






