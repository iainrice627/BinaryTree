@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Searching and Sorting App</h1>
    <p>
        A text tool that helps seach and display occurences of specific words from a large body of text.
    </p>
</div>

<div id="instructions">
    <!-- instructions drop down  -->
</div>
<hr>

<div id="textInput">
    <div class="text-center">
        <!-- INERT TEXT-->
        <h2>Insert text</h2>
        <p>
            Paste Text into the text box below
        </p>
    </div>
    <!-- scrolling feature for the text box-->
    <!--TEXT BOX FORM -->

    <form method="post" asp-controller="Home" asp-action="Index">
        <div>
            <label for="formGroupExampleInput" class="form-label">Text Box</label>
            <input type="text" class="form-control" id="formGroupExampleInput" placeholder="Text Box" name="inputText">
            <input class="btn btn-primary" type="submit" value="Submit">
        </div>
    </form>
</div>

<hr>

@if(ViewBag.Success == true)
