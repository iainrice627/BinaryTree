    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    @model List<KeyValuePair<string, int>>   
    @*define the type of object being passed in*@


    <table class="table">
        <thead>
            <tr>
                <th scope="col">Word</th>
                <th scope="col">Count</th>
            </tr>
        </thead>
        <tbody>
        @foreach(var item in Model){   @* model is always model but is the object being passed in*@
            <tr>
               
                <td>@item.Key</td>
                <td>@item.Value</td>
                
            </tr>
        }
            
        </tbody>
    </table>





}
