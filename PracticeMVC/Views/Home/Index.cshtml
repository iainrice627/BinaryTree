@model List<KeyValuePair<string, int>>

@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Searching and Sorting App</h1>
    <p>
        A text tool that helps search and display occurences of specific words from a large body of text.
    </p>
</div>

<div id="instructions">
    <!-- instructions drop down  -->
</div>
<hr>

<div id="textInput">
    <div class="text-center">
        <!-- INERT TEXT-->
        <h2>Insert text</h2>
        <p>
            Paste Text into the text box below
        </p>
    </div>
    <!-- scrolling feature for the text box-->
    <!--TEXT BOX FORM -->
    <div class="container mt-4">
        <div class="row">
            <div class="col-8">
                <div>
                    <form method="post" asp-controller="Home" asp-action="Index">
                        <div>
                            <input type="hidden" id="searchMethod" name="searchMethod" />
                            <input type="hidden" id="sortMethod" name="sortMethod" />

                            <label for="formGroupExampleInput" class="form-label"></label>
                            <textarea class="form-control big-box" id="inputText" name="inputText"placeholder="Enter text here"></textarea>
                            <input class="btn btn-primary mt-3" type="submit" value="Submit">

                        </div>
                    </form>
                </div>
            </div>
            <div class="col-4">
                <div class="row mb-3">
                    <div class="col-6">
                        <div class="dropdown mt-4">
                            <button class="btn btn-secondary dropdown-toggle" type="button" id="dropdownSearch" data-bs-toggle="dropdown" aria-expanded="false">
                                Select Search Method
                            </button>
                            <ul class="dropdown-menu" aria-labelledby="dropdownSearch">
                                <li><button class="dropdown-item" type="button"  onclick="setSearch('FL')">For Loop</button></li>
                                <li><button class="dropdown-item" type="button"  onclick="setSearch('BST')">Binary Search Tree</button></li>
                                <li><button class="dropdown-item" type="button"  onclick="setSearch('Other')">Other</button></li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-6">
                        <div class="dropdown mt-4">
                            <button class="btn btn-secondary dropdown-toggle" type="button" id="dropdownSort" data-bs-toggle="dropdown" aria-expanded="false">
                                Select Sort Method
                            </button>
                            <ul class="dropdown-menu" aria-labelledby="dropdownSort">
                                <li><a class="dropdown-item" href="#" onclick="setSort('BS')">BubbleSort</a></li>
                                <li><a class="dropdown-item" href="#" onclick="setSort('QS')">QuickSort</a></li>
                                <li><a class="dropdown-item" href="#" onclick="setSort('Other')">Other</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<hr>

@if(ViewBag.ShowMessage == true && ViewBag.ShowMessage != null)
{
    
    <div class="alert alert-success">
        This is a success message shown because ViewBag.ShowMessage is true.
    </div>

    <div id="tableContainer">
        @if (Model != null)
        {
            @await Html.PartialAsync("_table", Model)
        }
    </div>

}

<hr>














